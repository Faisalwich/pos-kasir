# =============================================
# KONFIGURASI POS KASIR
# Salin file ini jadi .env lalu isi semua nilai
# JANGAN commit file .env ke Git!
# =============================================

# --- DATABASE ---
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=password_mysql_kamu
DB_NAME=pos_kasir

# --- JWT ---
# Ganti dengan string random yang panjang dan unik!
# Contoh generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=ganti_dengan_string_random_panjang_dan_unik

# --- SERVER ---
PORT=3000
NODE_ENV=development

# --- LOGGING ---
# Level: error | warn | info | debug
LOG_LEVEL=info
